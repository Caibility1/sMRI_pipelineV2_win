{
  "name": "sMRI teaching demo",
  "image": "caibility1/smri_pipeline_demo:cloud-nomcr-v1-2026-07-23",
  "overrideCommand": true,
  "remoteEnv": {
    "FS_LICENSE": "${containerWorkspaceFolder}/.secrets/license.txt",
    "PIPELINE_DIR": "${containerWorkspaceFolder}",
    "PYTHON": "python3"
  },
  "postCreateCommand": "bash .devcontainer/post_create.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}